generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    USER // owns data (vault owner)
    DEVELOPER // requests & accesses data
    GUEST // verified SIWE but not onboarded yet
}

enum AppStatus {
    ACTIVE
    INACTIVE
}

enum AppTableStatus {
    ACTIVE
    ARCHIVED
}

enum AppColumnType {
    TEXT
    NUMBER
    BOOLEAN
    DATE_TIME
    JSON
    BIGINT
    FLOAT
    DOUBLE
    DECIMAL
    TIMESTAMP
    BINARY
    UUID
}

enum ConsentStatus {
    PENDING
    APPROVED
    REJECTED
    REVOKED
}

enum ConsentAction {
    REQUESTED
    APPROVED
    REJECTED
    REVOKED
}

model Account {
    id               String            @id @default(cuid())
    walletAddress    String            @unique
    role             Role?
    username         String?           @unique
    email            String?           @unique
    user             User?
    developer        Developer?
    consentAuditLogs ConsentAuditLog[]
    createdAt        DateTime          @default(now())
    updatedAt        DateTime          @updatedAt
}

model User {
    accountId       String           @id
    account         Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
    vaultRecords    VaultRecord[]
    consentRequests ConsentRequest[]
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt
}

model Developer {
    accountId       String           @id
    companyName     String?
    account         Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
    applications    Application[]
    consentRequests ConsentRequest[]
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt
}

model Application {
    id              String              @id @default(cuid())
    name            String
    description     String?
    status          AppStatus           @default(ACTIVE)
    developerId     String
    developer       Developer           @relation(fields: [developerId], references: [accountId], onDelete: Cascade)
    apiKeys         ApplicationApiKey[]
    tables          AppTable[]
    consentRequests ConsentRequest[]
    createdAt       DateTime            @default(now())
    updatedAt       DateTime            @updatedAt

    @@unique([developerId, name])
    @@index([developerId])
}

model ApplicationApiKey {
    id            String      @id @default(cuid())
    keyHash       String      @unique
    keyPrefix     String
    isActive      Boolean     @default(true)
    lastUsedAt    DateTime?
    applicationId String
    application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
    createdAt     DateTime    @default(now())
    updatedAt     DateTime    @updatedAt

    @@index([applicationId])
}

model AppTable {
    id              String           @id @default(cuid())
    name            String
    slug            String
    description     String?
    status          AppTableStatus   @default(ACTIVE)
    applicationId   String
    application     Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
    columns         AppTableColumn[]
    rows            AppTableRow[]
    consentRequests ConsentRequest[]
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt

    @@unique([applicationId, slug])
    @@index([applicationId])
}

model AppTableColumn {
    id                 String        @id @default(cuid())
    name               String
    key                String
    type               AppColumnType
    isRequired         Boolean       @default(false)
    isUnique           Boolean       @default(false)
    isPrimaryKey       Boolean       @default(false)
    isForeignKey       Boolean       @default(false)
    referencesTableId  String?
    referencesColumnId String?
    defaultValue       Json?
    isAutoIncrement    Boolean       @default(false)
    autoIncrementStart Int?
    autoIncrementStep  Int?
    isEncrypted        Boolean       @default(false)
    position           Int           @default(0)
    tableId            String
    table              AppTable      @relation(fields: [tableId], references: [id], onDelete: Cascade)
    createdAt          DateTime      @default(now())
    updatedAt          DateTime      @updatedAt

    @@unique([tableId, key])
    @@index([tableId])
    @@index([referencesTableId])
    @@index([referencesColumnId])
}

model AppTableRow {
    id        String   @id @default(cuid())
    tableId   String
    table     AppTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
    data      Json
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([tableId])
}

model VaultRecord {
    id            String   @id @default(cuid())
    userAccountId String
    user          User     @relation(fields: [userAccountId], references: [accountId], onDelete: Cascade)
    key           String   @unique
    value         String
    isEncrypted   Boolean  @default(true)
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    @@index([userAccountId])
}

model ConsentRequest {
    id                 String            @id @default(cuid())
    userAccountId      String
    user               User              @relation(fields: [userAccountId], references: [accountId], onDelete: Cascade)
    developerAccountId String
    developer          Developer         @relation(fields: [developerAccountId], references: [accountId], onDelete: Cascade)
    applicationId      String?
    application        Application?      @relation(fields: [applicationId], references: [id], onDelete: SetNull)
    tableId            String?
    table              AppTable?         @relation(fields: [tableId], references: [id], onDelete: SetNull)
    requestedFields    Json
    purpose            String?
    status             ConsentStatus     @default(PENDING)
    onChainHash        String?
    respondedAt        DateTime?
    logs               ConsentAuditLog[]
    createdAt          DateTime          @default(now())
    updatedAt          DateTime          @updatedAt

    @@index([userAccountId])
    @@index([developerAccountId])
    @@index([status])
}

model ConsentAuditLog {
    id               String         @id @default(cuid())
    consentRequestId String
    consentRequest   ConsentRequest @relation(fields: [consentRequestId], references: [id], onDelete: Cascade)
    actorAccountId   String
    actor            Account        @relation(fields: [actorAccountId], references: [id], onDelete: Cascade)
    action           ConsentAction
    statusSnapshot   ConsentStatus
    onChainHash      String?
    metadata         Json?
    createdAt        DateTime       @default(now())

    @@index([consentRequestId])
    @@index([actorAccountId])
}
