generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    USER  // owns data (vault owner)
    DEVELOPER // requests & accesses data
    GUEST // verified SIWE but not onboarded yet
}

model Account {
    id            String   @id @default(cuid())
    walletAddress String   @unique
    role          Role?
	email 	   String?  @unique
    user          User?      
    developer     Developer? 
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
}

model User {
    accountId String   @id
    username  String @unique
    account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Developer {
    accountId   String   @id
    username    String @unique
    companyName String?
    account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}